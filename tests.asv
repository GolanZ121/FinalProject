%% Scripts to examine the samples
clc; clear; close all;
% Params
Fs = 10e6;
scs = 15e3;
NFFT = 1024;
og_Fs = scs * NFFT;
number_of_symbols = 9;
cp_len = 72;
ext_cp_len = 80;
SPP = 9*NFFT + cp_len * 7 + ext_cp_len * 2; % Samples per packet
time_of_packet = SPP / og_Fs;

% load the raw_samples file 
filename = 'raw_samples/raw_samples_12_Feb_2026_13_28_20_614_fs_10MHz.32fc';
fid = fopen(filename, 'r');

% Read all data as 32-bit floats
data = fread(fid, [2, Inf], 'float32=>double');
fclose(fid);
data = complex(data(1,:), data(2,:));

numSamples = length(data);
TotalTime = numSamples / Fs;
time = (0:numSamples-1) / Fs;

figure;
spectrogram(data,64,32,1024,Fs,'yaxis', 'centered')

ZC600 = zadoffChuSeq(600, 601);
ZC600PAD = [zeros(212, 1); ZC600; zeros(211, 1)];
ZC600OFDM = ifft(ifftshift(ZC600PAD));

ZC147 = zadoffChuSeq(147, 601);
ZC147PAD = [zeros(212, 1); ZC147; zeros(211, 1)];
ZC147OFDM = ifft(ifftshift(ZC147PAD));

data = resample(data, og_Fs, Fs);

[c1, idx1] = cross_corr(ZC600OFDM, data);
[c2, idx2] = cross_corr(ZC147OFDM, data);

figure;
plot(1:length(c1), [abs(c1); abs(c2)]);

%%
starting_idx = idx1 - 3*NFFT - cp_len*2 -ext_cp_len + 1;
ending_idx = starting_idx + NFFT * number_of_symbols + 2*ext_cp_len + 7*cp_len - 1;

time_synced_data = data(starting_idx:ending_idx);

figure;
spectrogram(time_synced_data,64,32,NFFT,og_Fs,'yaxis', 'centered')

firstcp = time_synced_data(1:ext_cp_len);
secondcp = time_synced_data(NFFT+1: NFFT+ext_cp_len);
plot(lenf[firstcp; secondcp]);
%% Get the forth symbol (The revcieved ZC sequence)
forth_sym_start = 3*NFFT + 3*cp_len + ext_cp_len + 1;
forth_sym_end = forth_sym_start + NFFT -1;
forth_symbol = time_synced_data(forth_sym_start:forth_sym_end);

%% Find coarse frequency offset
[X, freqs] = plot_fft(forth_symbol' .* ZC600OFDM, og_Fs);
[~, max_freq_idx] = max(X);
freq_offset = freqs(max_freq_idx);

%% Correct the coarse frequency offset
time = linspace(0,SPP/og_Fs,SPP);
freq_synced_data = time_synced_data .* exp(1j * 2 * pi * freq_offset *time);

forth_symbol = freq_synced_data(forth_sym_start:forth_sym_end);
plot_fft(forth_symbol' .* ZC600OFDM, og_Fs)

function [conv_res, max_idx] = cross_corr(sig2, sig1)
    conv_res = conv(sig1, flip(conj(sig2)), "valid");
    [~, max_idx] = max(conv_res);
end

function [X, freqs] = plot_fft(signal, Fs)
arguments
    signal 
    Fs 
end
    X = fftshift(fft(signal));
    freqs = linspace(-Fs/2, Fs/2, length(X));
    figure;
    plot(freqs, (abs(X)));

end

function [sig, new_time_axis] = chopSignal(signal, Fs, start_ms, end_ms)
    time = (0:length(signal)-1) / Fs;
    startIdx = start_ms * Fs * 1e-3+ 1;
    endIdx = end_ms * Fs * 1e-3;
    new_time_axis = time(startIdx:endIdx);
    sig = signal(startIdx:endIdx); % Extract the signal segment based on the provided time range
end